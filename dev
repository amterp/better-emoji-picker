#!/usr/bin/env rad
---
Build, package, and release BEP (Better Emoji Picker).
---

args:
    version str?                       # Version to release (e.g., 1.0.0)
    tap_path str = "../homebrew-tap"   # Path to homebrew-tap repo
    notary_profile str = "bep-notary"  # notarytool keychain profile name
    skip_build bool                    # Skip build, use existing .app
    skip_notarize bool                 # Skip signing checks + notarization (produces an UNSHIPPABLE artifact)
    push p bool                        # Push current branch to origin (requires clean git state)

    version regex r"^\d+\.\d+\.\d+$"

// Notarization requires a Developer ID Application cert and a notarytool
// keychain profile. See the "Releasing" section of SPEC.md for one-time setup.
TEAM_ID = "CV4835A2BN"

if version:
    // Paths
    stdout = quiet $`pwd`
    repo = stdout.trim()
    project = "{repo}/BetterEmojiPicker"
    build_dir = "{repo}/build"
    app_path = "{build_dir}/Build/Products/Release/BetterEmojiPicker.app"
    zip_path = "{repo}/releases/BetterEmojiPicker-{version}.zip"
    cask_path = "{repo}/{tap_path}/Casks/bep.rb"
    tag = "v{version}"

    // Preflight: fail before burning a build on missing credentials.
    if not skip_notarize:
        print("Preflight...")

        stdout = quiet $`security find-identity -v -p codesigning`
        if stdout.count("Developer ID Application") == 0:
            print_err("No 'Developer ID Application' certificate found in the keychain.")
            print_err("Create one: Xcode > Settings > Accounts > Manage Certificates > + > Developer ID Application")
            exit(1)

        // Live round-trip to Apple. Catches revoked keys and notary outages now
        // rather than after a full universal build.
        quiet $`xcrun notarytool history --keychain-profile {notary_profile}` catch:
            print_err("notarytool credentials for profile '{notary_profile}' are missing or rejected.")
            print_err("Re-run: xcrun notarytool store-credentials \"{notary_profile}\" --key <p8> --key-id <id> --issuer <uuid>")
            exit(1)

    // Build
    if not skip_build:
        print("Building...")
        quiet $`rm -rf {build_dir}` catch:
            pass

        // CURRENT_PROJECT_VERSION must increase monotonically. Commit count does
        // that for free, and unlike the semver string it survives 0.9.0 -> 0.10.0.
        stdout = quiet $`git rev-list --count HEAD`
        build_num = stdout.trim()

        // Version is passed as a build setting rather than committed to the
        // pbxproj, so releases leave no dirty diff behind. GENERATE_INFOPLIST_FILE
        // turns these into CFBundleShortVersionString / CFBundleVersion.
        //
        // -destination is load-bearing: without it xcodebuild narrows to the
        // native arch and silently produces a thin binary.
        $`xcodebuild -project {project}/BetterEmojiPicker.xcodeproj -scheme BetterEmojiPicker -configuration Release -derivedDataPath {build_dir} -destination "generic/platform=macOS" ARCHS="arm64 x86_64" ONLY_ACTIVE_ARCH=NO MARKETING_VERSION={version} CURRENT_PROJECT_VERSION={build_num} build`

    // Verify what we actually built.
    //
    // These gates are why this script uses plain `xcodebuild build` rather than
    // `archive` + `-exportArchive`: the app bundle embeds no frameworks or helper
    // executables, so there is no nested code for export to re-sign. Revisit that
    // choice if a framework, XPC service, helper tool, or Sparkle is ever added.
    print("Verifying build...")

    stdout = quiet $`lipo -archs {app_path}/Contents/MacOS/BetterEmojiPicker`
    archs = stdout.trim()
    if archs.count("arm64") == 0 or archs.count("x86_64") == 0:
        print_err("Expected a universal binary, got: {archs}")
        exit(1)

    stdout = quiet $`defaults read {app_path}/Contents/Info.plist CFBundleShortVersionString`
    built_version = stdout.trim()
    if built_version != version:
        print_err("Built app reports version {built_version}, expected {version}.")
        exit(1)

    if not skip_notarize:
        // codesign writes its report to stderr, hence the redirects. Without them
        // these checks compare against an empty string and silently pass.
        $`codesign --verify --strict --verbose=2 {app_path}`

        stdout = quiet $`codesign -d --entitlements - --xml {app_path} 2>/dev/null`
        if stdout.count("get-task-allow") > 0:
            print_err("Shipped app carries com.apple.security.get-task-allow.")
            print_err("The Release config is not signing with a Developer ID identity. Aborting.")
            exit(1)

        stdout = quiet $`codesign -dvvv {app_path} 2>&1`
        // Match the flag name rather than the exact hex: the numeric value
        // legitimately varies as other signing flags are set alongside it.
        expected = ["Authority=Developer ID Application", "TeamIdentifier={TEAM_ID}", "(runtime)", "Timestamp="]
        for needle in expected:
            if stdout.count(needle) == 0:
                print_err("Signature check failed, missing: {needle}")
                exit(1)

        // Notarize. The submitted zip is a throwaway transport container: the
        // ticket is stapled into the .app, not the archive, so the release zip
        // must be built afterwards from the stapled bundle.
        print("Notarizing (this usually takes a few minutes)...")
        notarize_zip = "{build_dir}/notarize.zip"
        $`ditto -c -k --keepParent {app_path} {notarize_zip}`

        stdout = quiet $`xcrun notarytool submit {notarize_zip} --keychain-profile {notary_profile} --wait --timeout 45m --output-format json`
        result = parse_json(stdout)
        submission = result.id ?? "unknown"
        // notarytool has historically exited 0 even when the result is Invalid,
        // so trust the payload rather than the exit code.
        status = result.status ?? ""

        // On timeout there is no status field at all, just a message. That is not
        // a rejection: the submission is still queued on Apple's side, and the
        // first submission from a new account can take well over 20 minutes.
        if status == "":
            print_err("Notarization did not return a verdict in time.")
            print_err("The submission is still processing, not rejected. Check it with:")
            print_err("  xcrun notarytool info {submission} --keychain-profile {notary_profile}")
            print_err("Once it reports Accepted, re-run with --skip-build to staple and publish.")
            exit(1)

        if status != "Accepted":
            print_err("Notarization {status} (submission {submission}).")
            $`xcrun notarytool log {submission} --keychain-profile {notary_profile}`
            exit(1)

        print("Stapling...")
        $`xcrun stapler staple {app_path}` catch:
            // Error 65 means the ticket has not reached Apple's CDN yet.
            print("Staple failed, retrying...")
            sleep(15)
            $`xcrun stapler staple {app_path}`

        $`xcrun stapler validate {app_path}`
        $`spctl --assess --type execute -vvv {app_path}`

    // Package
    print("Packaging...")
    $`mkdir -p {repo}/releases`
    quiet $`rm -f {zip_path}` catch:
        pass
    $`ditto -c -k --keepParent {app_path} {zip_path}`

    // SHA256
    stdout = quiet $`shasum -a 256 {zip_path}`
    sha256 = stdout.split(" ")[0]

    // Git tag
    print("Tagging...")
    $`git tag {tag}`

    // GitHub release
    print("Creating GitHub release...")
    $`gh release create {tag} {zip_path} --repo amterp/better-emoji-picker --title "BEP {tag}" --notes "BEP {tag}"` catch:
        print_err("Release creation failed. Local tag {tag} still exists.")
        print_err("Delete it before retrying: git tag -d {tag}")
        exit(1)

    // Update cask.
    // NB: these rewrites are regex-based and assume the cask contains exactly one
    // `version "..."` and one `sha256 "..."`. Keep it that way.
    print("Updating cask...")
    cask = str(read_file(cask_path).content)
    cask = replace(cask, 'version "[^"]*"', 'version "{version}"')
    cask = replace(cask, 'sha256 "[^"]*"', 'sha256 "{sha256}"')
    write_file(cask_path, cask)

    // Push tap
    print("Pushing tap...")
    tap = "{repo}/{tap_path}"
    $`git -C {tap} add Casks/bep.rb`
    $`git -C {tap} commit -m "bep {version}"`
    $`git -C {tap} push`

    print("Done! {tag} released.")

// Push to origin
if push:
    print("Pushing to origin...")
    stdout = quiet $`git status --porcelain`
    if stdout.trim() != "":
        print_err("Error: git has uncommitted changes. Commit or stash before pushing.")
        exit(1)
    $`git push origin HEAD --tags`
